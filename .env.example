# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Settings module — change per environment
# dev:     config.settings.dev
# prod:    config.settings.prod
DJANGO_SETTINGS_MODULE=config.settings.dev

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DBENGINE=postgresql
DBNAME=nbes_db
DBHOST=localhost
# Docker Compose sets DBHOST to the db service alias by default. Override with
# NBES_DBHOST only when the database is outside the Compose network.
NBES_DBHOST=nbes-db
DBUSER=postgres
DBPASSWORD=your-db-password
DBPORT=5432

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
# Docker Compose default for in-network Redis.
NBES_REDIS_URL=redis://redis:6379/0

# ── Kafka ─────────────────────────────────────────────────────────────────────
# In dev, events are written to OutboxEvent table only (Kafka not required).
# Set this in staging/production to enable real Kafka publishing.
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_ENABLED=False

# ── Authentication (Keycloak) ─────────────────────────────────────────────────
# In dev, a shared JWT secret is used (no Keycloak container needed).
# In production, point to the Keycloak realm.
JWT_SECRET_KEY=shared-jwt-secret-between-iam-and-nbes
KEYCLOAK_REALM_URL=http://keycloak:8080/realms/clet-internal
# Set KEYCLOAK_ENABLED=True in production to use JWKS validation.
KEYCLOAK_ENABLED=False

# NBES's own Keycloak backend client. Tokens must list this in `aud` and
# NBES reads its system roles from resource_access[NBES_CLIENT_ID].roles.
NBES_CLIENT_ID=nbes-api
# Comma-separated audiences this service will accept. Must include
# NBES_CLIENT_ID. Empty disables audience verification (dev only).
KEYCLOAK_VALID_AUDIENCES=nbes-api

# ── MinIO / Object Storage ────────────────────────────────────────────────────
# In dev, files are stored locally. Set MINIO_ENABLED=True to use MinIO.
MINIO_ENABLED=False
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=nbes-bucket
MINIO_USE_SSL=False

# ── Vault / HSM ───────────────────────────────────────────────────────────────
# In dev, AES key is derived from SECRET_KEY (software stub).
# In production, set PKCS11_LIB_PATH to the HSM library path.
VAULT_DEV_MODE=True
PKCS11_LIB_PATH=/usr/lib/softhsm/libsofthsm2.so
HSM_TOKEN_LABEL=nbes-vault
HSM_PIN=

# ── External Systems ──────────────────────────────────────────────────────────
# System 17 — inter-service communication gateway
SYSTEM_17_URL=http://localhost:9017
SYSTEM_17_API_KEY=
# HMAC secret shared with System 17. Required in prod when KAFKA_ENABLED=True.
# Used by shared.integrations.call_system_17 to sign payloads.
SYSTEM_17_HMAC_SECRET=
# Per-attempt timeout (seconds) and replay-protection nonce window (seconds).
SYSTEM_17_TIMEOUT_SECONDS=5
SYSTEM_17_NONCE_WINDOW_SECONDS=300

# Idempotency cache TTL — how long a replay of an Idempotency-Key returns
# the cached response. 24h default.
IDEMPOTENCY_CACHE_TTL_SECONDS=86400
EDGE_THROTTLE_THRESHOLD=100
EDGE_BLOCK_THRESHOLD_24H=1000
EDGE_SECURITY_EVENT_RETENTION_DAYS=90

# System 20 — payments webhook HMAC secret
SYSTEM_20_WEBHOOK_SECRET=

# System 21 — communications (email/SMS)
SYSTEM_21_URL=http://localhost:9021
SYSTEM_21_API_KEY=

# NLEMS (System 06) — eligibility verification
NLEMS_URL=http://localhost:9006
NLEMS_API_KEY=

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ── Time Zone ─────────────────────────────────────────────────────────────────
TIME_ZONE=Africa/Accra

KEYCLOAK_URL=http://keycloak:8080/
KEYCLOAK_REALM_INTERNAL=clet-internal
KEYCLOAK_REALM_INSTITUTIONS=institutions
KEYCLOAK_CLIENT_ID_INTERNAL=clet-iam-internal
KEYCLOAK_CLIENT_SECRET_INTERNAL=change-me
KEYCLOAK_CLIENT_ID_INSTITUTIONS=clet-iam-institutions
KEYCLOAK_CLIENT_SECRET_INSTITUTIONS=change-me
